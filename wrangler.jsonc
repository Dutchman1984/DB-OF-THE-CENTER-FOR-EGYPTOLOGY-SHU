{
  "name": "corpus-aegyptiacum",
  "main": "worker.mjs",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "preview_urls": false,
  "triggers": {
    "crons": [
      "17 */6 * * *"
    ]
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "shu-egyptology-db.site",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  }
}
